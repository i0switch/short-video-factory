  "cues": [
    { "id": "c1", "type": "title_display", "frame": 0, "params": { "seriesTitle": "スカッと迷言集", "episodeTitle": "会計よろしく", "persistent": true, "titleColor": "#FF0000" } },
    { "id": "c2", "type": "caption_change", "frame": 42, "params": { "text": "今日ランチでもどう？義妹も一緒よ" } },
    { "id": "c3", "type": "caption_change", "frame": 84, "params": { "text": "店に着くと" } },
    { "id": "c4", "type": "caption_change", "frame": 126, "params": { "text": "あ、来た来た！" } },
    { "id": "c5", "type": "caption_change", "frame": 168, "params": { "text": "お手洗い行ってくるわ" } },
    { "id": "c6", "type": "caption_change", "frame": 210, "params": { "text": "私も〜" } },
    { "id": "c7", "type": "speaker_change", "frame": 252, "params": { "speaker": "character1", "text": "いつまで経っても帰ってこない…" } },
    { "id": "c8", "type": "speaker_change", "frame": 294, "params": { "speaker": "narrator", "text": "LINEも既読無視" } },
    { "id": "c9", "type": "speaker_change", "frame": 336, "params": { "speaker": "character2", "text": "お会計4800円になります" } },
    { "id": "c10", "type": "speaker_change", "frame": 378, "params": { "speaker": "character1", "text": "え？3人分を私が…？" } },
    { "id": "c11", "type": "speaker_change", "frame": 420, "params": { "speaker": "narrator", "text": "強制おごりはこれだけに留まらず" } },
    { "id": "c12", "type": "speaker_change", "frame": 462, "params": { "speaker": "character2", "text": "あら〜財布忘れちゃった" } },
    { "id": "c13", "type": "caption_change", "frame": 504, "params": { "text": "今日カード持ってないや〜" } },
    { "id": "c14", "type": "speaker_change", "frame": 546, "params": { "speaker": "narrator", "text": "もうトータル10万以上奢らされてる" } },
    { "id": "c15", "type": "caption_change", "frame": 588, "params": { "text": "旦那に相談すると" } },
    { "id": "c16", "type": "speaker_change", "frame": 630, "params": { "speaker": "character1", "text": "ふざけんな！文句言ってくる！" } },
    { "id": "c17", "type": "speaker_change", "frame": 672, "params": { "speaker": "character2", "text": "なによ！家族なんだからいいでしょ！" } },
    { "id": "c18", "type": "caption_change", "frame": 714, "params": { "text": "稼いでるんでしょ？ケチくさい嫁ね！" } },
    { "id": "c19", "type": "speaker_change", "frame": 756, "params": { "speaker": "narrator", "text": "ダメだ…やっぱり聞く耳持たない" } },
    { "id": "c20", "type": "caption_change", "frame": 798, "params": { "text": "さすがに舐められすぎて" } },
    { "id": "c21", "type": "caption_change", "frame": 840, "params": { "text": "堪忍袋爆発" } },
    { "id": "c22", "type": "caption_change", "frame": 882, "params": { "text": "翌日罠を張る" } },
    { "id": "c23", "type": "speaker_change", "frame": 924, "params": { "speaker": "character1", "text": "この前会社から臨時ボーナス出たんですよ〜" } },
    { "id": "c24", "type": "speaker_change", "frame": 966, "params": { "speaker": "character2", "text": "あら！いくら？" } },
    { "id": "c25", "type": "speaker_change", "frame": 1008, "params": { "speaker": "character1", "text": "50万円も出たんです！" } },
    { "id": "c26", "type": "caption_change", "frame": 1050, "params": { "text": "また美味しいもの食べ行きたいですね〜" } },
    { "id": "c27", "type": "speaker_change", "frame": 1092, "params": { "speaker": "character2", "text": "今度は高級店行きたい！" } },
    { "id": "c28", "type": "speaker_change", "frame": 1133, "params": { "speaker": "narrator", "text": "数日後" } },
    { "id": "c29", "type": "speaker_change", "frame": 1174, "params": { "speaker": "character2", "text": "土曜日の夜ご飯一緒にどう？" } },
    { "id": "c30", "type": "speaker_change", "frame": 1215, "params": { "speaker": "narrator", "text": "そして土曜日の夜" } },
    { "id": "c31", "type": "caption_change", "frame": 1256, "params": { "text": "義母たちから鬼ライン" } },
    { "id": "c32", "type": "speaker_change", "frame": 1297, "params": { "speaker": "character2", "text": "なんで来ないの！もう予約時間よ！" } },
    { "id": "c33", "type": "caption_change", "frame": 1338, "params": { "text": "早く来なさいよ！" } },
    { "id": "c34", "type": "speaker_change", "frame": 1379, "params": { "speaker": "narrator", "text": "機内モードに切り替えて無視" } },
    { "id": "c35", "type": "speaker_change", "frame": 1420, "params": { "speaker": "character1", "text": "ハワイ楽しみだね！" } },
    { "id": "c36", "type": "caption_change", "frame": 1461, "params": { "text": "いやー最高だね！" } },
    { "id": "c37", "type": "speaker_change", "frame": 1502, "params": { "speaker": "narrator", "text": "翌日義父から連絡" } },
    { "id": "c38", "type": "caption_change", "frame": 1543, "params": { "text": "義母と義妹が食い逃げで捕まったらしい" } },
    { "id": "c39", "type": "caption_change", "frame": 1584, "params": { "text": "これを機に離婚するみたい" } },
    { "id": "c40", "type": "speaker_change", "frame": 1625, "params": { "speaker": "character1", "text": "父さんやっと決心してくれたな" } },
    { "id": "c41", "type": "caption_change", "frame": 1666, "params": { "text": "私たちも海外旅行から帰ったら" } },
    { "id": "c42", "type": "caption_change", "frame": 1707, "params": { "text": "新天地に引っ越しね" } },
    { "id": "c43", "type": "speaker_change", "frame": 1748, "params": { "speaker": "narrator", "text": "あの2人は寄生先いなくなって" } },
    { "id": "c44", "type": "caption_change", "frame": 1789, "params": { "text": "これからどうするんだろう？" } },
    { "id": "c45", "type": "episode_change", "frame": 1830, "params": { "episodeTitle": "彼女を紹介" } },
    { "id": "c46", "type": "speaker_change", "frame": 1830, "params": { "speaker": "character1", "text": "タケシ！紹介するよ婚約者の美咲" } },
    { "id": "c47", "type": "speaker_change", "frame": 1930, "params": { "speaker": "character2", "text": "初めまして" } },
    { "id": "c48", "type": "speaker_change", "frame": 2030, "params": { "speaker": "narrator", "text": "タケシの顔が一瞬で真っ青に" } },
    { "id": "c49", "type": "speaker_change", "frame": 2130, "params": { "speaker": "character1", "text": "おいおい美人すぎて固まったか？ｗ" } },
    { "id": "c50", "type": "caption_change", "frame": 2230, "params": { "text": "あ、いや…おめでとう" } },
    { "id": "c51", "type": "speaker_change", "frame": 2330, "params": { "speaker": "narrator", "text": "3日後タケシから呼び出し" } },
    { "id": "c52", "type": "speaker_change", "frame": 2430, "params": { "speaker": "character1", "text": "イッチ…言いにくいんだけど" } },
    { "id": "c53", "type": "caption_change", "frame": 2530, "params": { "text": "美咲さん実は高校の同級生なんだ" } },
    { "id": "c54", "type": "caption_change", "frame": 2630, "params": { "text": "俺、あいつにいじめられてた" } },
    { "id": "c55", "type": "caption_change", "frame": 2730, "params": { "text": "階段から落ちて怪我した子とか" } },
    { "id": "c56", "type": "caption_change", "frame": 2830, "params": { "text": "親が社長だからもみ消されたんだ" } },
    { "id": "c57", "type": "speaker_change", "frame": 2930, "params": { "speaker": "character2", "text": "うちに示談金たかって来たのよ" } },
    { "id": "c58", "type": "caption_change", "frame": 3030, "params": { "text": "イッチ君来てくれてありがとう" } },
    { "id": "c59", "type": "speaker_change", "frame": 3130, "params": { "speaker": "character1", "text": "あいつがその同級生だよ" } },
    { "id": "c60", "type": "caption_change", "frame": 3230, "params": { "text": "言ったことと正反対だったよ" } },
    { "id": "c61", "type": "caption_change", "frame": 3330, "params": { "text": "君たちは俺の思ってるような人たちじゃなかった" } },
    { "id": "c62", "type": "speaker_change", "frame": 3430, "params": { "speaker": "narrator", "text": "過去の出来事を週刊誌にタレコミ" } },
    { "id": "c63", "type": "caption_change", "frame": 3530, "params": { "text": "大切な親友は失わなかった" } },
    { "id": "c64", "type": "episode_change", "frame": 3630, "params": { "episodeTitle": "子供好き" } },
    { "id": "c65", "type": "caption_change", "frame": 3630, "params": { "text": "付き合ってる彼女が妊娠" } },
    { "id": "c66", "type": "caption_change", "frame": 3755, "params": { "text": "想定外の学生結婚" } },
    { "id": "c67", "type": "caption_change", "frame": 3880, "params": { "text": "夜泣きで寝不足でも可愛い娘" } },
    { "id": "c68", "type": "caption_change", "frame": 4005, "params": { "text": "テーブルに置き手紙" } },
    { "id": "c69", "type": "caption_change", "frame": 4130, "params": { "text": "娘を育てることに" } },
    { "id": "c70", "type": "caption_change", "frame": 4255, "params": { "text": "皆に愛されて育った娘は" } },
