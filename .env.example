# ============================================================
# LLM 設定（LLM_PROVIDER に応じてどちらか片方のキーを設定）
# ============================================================
LLM_PROVIDER=openai        # openai | anthropic

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI互換APIのベースURL（省略時: https://api.openai.com/v1）
# Alibaba Cloud (DashScope) を使う場合:
# OPENAI_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1

# 省略時のデフォルトモデル:
#   openai    → gpt-4o
#   anthropic → claude-3-5-sonnet-20241022
# LLM_MODEL=gpt-4o

# ============================================================
# Pexels 画像 API（省略するとローカル fallback 画像を使用）
# 無料プランでも利用可: https://www.pexels.com/api/
# ============================================================
# PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# VOICEVOX 設定（変更不要な場合はコメントアウトのまま）
# ============================================================
# VOICEVOX_URL=http://localhost:50021   # WSL2の場合は Windows IP を指定
# VOICEVOX_SPEAKER=3                   # 話者ID (0=四国めたん, 1=ずんだもん, 3=春日部つむぎ)
# VOICEVOX_GAIN=1.5                    # 音量倍率 (1.0=等倍, 2.0=2倍)
