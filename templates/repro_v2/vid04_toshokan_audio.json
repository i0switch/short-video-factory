{
  "tts": [
    {
      "id": "a1",
      "text": "図書館に本を借りに来たら",
      "speaker": "narrator",
      "startFrame": 0,
      "endFrame": 97
    },
    {
      "id": "a2",
      "text": "んゴゴゴゴゴゴーゴゴごっ！",
      "speaker": "narrator",
      "startFrame": 98,
      "endFrame": 157
    },
    {
      "id": "a3",
      "text": "え、今の音なに！？",
      "speaker": "character2",
      "startFrame": 158,
      "endFrame": 253
    },
    {
      "id": "a4",
      "text": "って周りを見渡したら",
      "speaker": "narrator",
      "startFrame": 254,
      "endFrame": 375
    },
    {
      "id": "a5",
      "text": "百貫が椅子並べて仰向けで大イビキ！",
      "speaker": "narrator",
      "startFrame": 376,
      "endFrame": 501
    },
    {
      "id": "a6",
      "text": "しばらくすると静かになった！",
      "speaker": "narrator",
      "startFrame": 502,
      "endFrame": 619
    },
    {
      "id": "a7",
      "text": "自分のいびきにビクッとして",
      "speaker": "narrator",
      "startFrame": 620,
      "endFrame": 735
    },
    {
      "id": "a8",
      "text": "って寝言みたいに言った後また寝たぁぁぁ！？",
      "speaker": "narrator",
      "startFrame": 736,
      "endFrame": 882
    },
    {
      "id": "a9",
      "text": "これ絶対わざとじゃない！？",
      "speaker": "narrator",
      "startFrame": 883,
      "endFrame": 960
    },
    {
      "id": "a10",
      "text": "と思って",
      "speaker": "narrator",
      "startFrame": 961,
      "endFrame": 1068
    },
    {
      "id": "a11",
      "text": "落ちてたしおりを百貫の額にペタッ！",
      "speaker": "narrator",
      "startFrame": 1069,
      "endFrame": 1188
    },
    {
      "id": "a12",
      "text": "カッ！と目を見開くから",
      "speaker": "narrator",
      "startFrame": 1189,
      "endFrame": 1307
    },
    {
      "id": "a13",
      "text": "一瞬キョンシー！？",
      "speaker": "narrator",
      "startFrame": 1308,
      "endFrame": 1395
    },
    {
      "id": "a14",
      "text": "そのまま椅子から転げ落ちて大きな音を立てると",
      "speaker": "narrator",
      "startFrame": 1396,
      "endFrame": 1547
    },
    {
      "id": "a15",
      "text": "静粛にお願いします！",
      "speaker": "character1",
      "startFrame": 1548,
      "endFrame": 1727
    },
    {
      "id": "a16",
      "text": "いや私、寝てません！考え事してただけで",
      "speaker": "character2",
      "startFrame": 1728,
      "endFrame": 1905
    },
    {
      "id": "a17",
      "text": "しおり貼ったまま必死に言い訳するから",
      "speaker": "narrator",
      "startFrame": 1906,
      "endFrame": 2007
    },
    {
      "id": "a18",
      "text": "起きてるよね？って思ったので",
      "speaker": "narrator",
      "startFrame": 2008,
      "endFrame": 2099
    },
    {
      "id": "a19",
      "text": "何考えてたんですか？って聞くと",
      "speaker": "narrator",
      "startFrame": 2100,
      "endFrame": 2213
    },
    {
      "id": "a20",
      "text": "何考えようか考えてました！",
      "speaker": "character2",
      "startFrame": 2214,
      "endFrame": 2339
    },
    {
      "id": "a21",
      "text": "一瞬、館内が止まると",
      "speaker": "narrator",
      "startFrame": 2340,
      "endFrame": 2445
    },
    {
      "id": "a22",
      "text": "では、その考え事は外でお願いします",
      "speaker": "character1",
      "startFrame": 2446,
      "endFrame": 2573
    },
    {
      "id": "a23",
      "text": "百貫 え？って固まって",
      "speaker": "narrator",
      "startFrame": 2574,
      "endFrame": 2639
    },
    {
      "id": "a24",
      "text": "ここは本を読む場所なので",
      "speaker": "character1",
      "startFrame": 2640,
      "endFrame": 2739
    },
    {
      "id": "a25",
      "text": "職員に言われて",
      "speaker": "narrator",
      "startFrame": 2740,
      "endFrame": 2819
    },
    {
      "id": "a26",
      "text": "周りの利用者の冷たい目線が一斉に百貫に向くと",
      "speaker": "narrator",
      "startFrame": 2820,
      "endFrame": 2919
    },
    {
      "id": "a27",
      "text": "あ、あの、その、考え事が…",
      "speaker": "character2",
      "startFrame": 2920,
      "endFrame": 3019
    },
    {
      "id": "a28",
      "text": "最後まで言えず",
      "speaker": "narrator",
      "startFrame": 3020,
      "endFrame": 3079
    },
    {
      "id": "a29",
      "text": "ひょこひょこ立ち去った時",
      "speaker": "narrator",
      "startFrame": 3080,
      "endFrame": 3139
    },
    {
      "id": "a30",
      "text": "しおりが落ちた",
      "speaker": "narrator",
      "startFrame": 3140,
      "endFrame": 3199
    },
    {
      "id": "a31",
      "text": "今日借りた本のタイトルは",
      "speaker": "narrator",
      "startFrame": 3200,
      "endFrame": 3259
    },
    {
      "id": "a32",
      "text": "言われた通りに動く方法",
      "speaker": "narrator",
      "startFrame": 3260,
      "endFrame": 3319
    },
    {
      "id": "a33",
      "text": "私は本を開いて",
      "speaker": "narrator",
      "startFrame": 3320,
      "endFrame": 3379
    },
    {
      "id": "a34",
      "text": "拾ったしおりを挟んで",
      "speaker": "narrator",
      "startFrame": 3380,
      "endFrame": 3439
    },
    {
      "id": "a35",
      "text": "これ、もう読まなくていいな",
      "speaker": "narrator",
      "startFrame": 3440,
      "endFrame": 3499
    },
    {
      "id": "a36",
      "text": "という音が聞こえた気がしたw",
      "speaker": "narrator",
      "startFrame": 3500,
      "endFrame": 3561
    }
  ],
