{
  "tts": [
    {
      "id": "a1",
      "text": "クラス全員で示し合わせて、",
      "speaker": "narrator",
      "startFrame": 0,
      "endFrame": 43
    },
    {
      "id": "a2",
      "text": "授業中みんなで一切動かなくなった。",
      "speaker": "narrator",
      "startFrame": 44,
      "endFrame": 188
    },
    {
      "id": "a3",
      "text": "ある者は消しゴムを拾おうとしてる最中で止まり、",
      "speaker": "narrator",
      "startFrame": 189,
      "endFrame": 296
    },
    {
      "id": "a4",
      "text": "ある者は先生に質問しようとして",
      "speaker": "narrator",
      "startFrame": 297,
      "endFrame": 365
    },
    {
      "id": "a5",
      "text": "挙手しかけたところで止まる。",
      "speaker": "narrator",
      "startFrame": 366,
      "endFrame": 433
    },
    {
      "id": "a6",
      "text": "ご丁寧にもクラスの中でも器用な奴が、",
      "speaker": "narrator",
      "startFrame": 434,
      "endFrame": 490
    },
    {
      "id": "a7",
      "text": "時計もその時間で止まるようにしておいた。",
      "speaker": "narrator",
      "startFrame": 491,
      "endFrame": 590
    },
    {
      "id": "a8",
      "text": "ドアも窓も一切閉め切っていたので",
      "speaker": "narrator",
      "startFrame": 591,
      "endFrame": 646
    },
    {
      "id": "a9",
      "text": "完全に無音になる。",
      "speaker": "narrator",
      "startFrame": 647,
      "endFrame": 784
    },
    {
      "id": "a10",
      "text": "授業にくる全ての教師に試したが、",
      "speaker": "narrator",
      "startFrame": 785,
      "endFrame": 860
    },
    {
      "id": "a11",
      "text": "皆同じような反応するのが笑えた",
      "speaker": "narrator",
      "startFrame": 861,
      "endFrame": 895
    },
    {
      "id": "a12",
      "text": "え？ え？",
      "speaker": "character2",
      "startFrame": 896,
      "endFrame": 936
    },
    {
      "id": "a13",
      "text": "何？ 何で？",
      "speaker": "character2",
      "startFrame": 937,
      "endFrame": 997
    },
    {
      "id": "a14",
      "text": "みたいな反応",
      "speaker": "narrator",
      "startFrame": 998,
      "endFrame": 1024
    },
    {
      "id": "a15",
      "text": "ものすごくキョドった",
      "speaker": "narrator",
      "startFrame": 1025,
      "endFrame": 1043
    },
    {
      "id": "a16",
      "text": "数学",
      "speaker": "narrator",
      "startFrame": 1044,
      "endFrame": 1070
    },
    {
      "id": "a17",
      "text": "こいつだけ何故か普通に授業を進めた",
      "speaker": "narrator",
      "startFrame": 1071,
      "endFrame": 1100
    },
    {
      "id": "a18",
      "text": "ポカーン",
      "speaker": "narrator",
      "startFrame": 1101,
      "endFrame": 1115
    },
    {
      "id": "a19",
      "text": "まさしくこのAAの状態",
      "speaker": "narrator",
      "startFrame": 1116,
      "endFrame": 1146
    },
    {
      "id": "a20",
      "text": "理科",
      "speaker": "narrator",
      "startFrame": 1147,
      "endFrame": 1165
    },
    {
      "id": "a21",
      "text": "現文の教師と全く同じ。",
      "speaker": "narrator",
      "startFrame": 1166,
      "endFrame": 1192
    },
    {
      "id": "a22",
      "text": "皆が動き出すと",
      "speaker": "narrator",
      "startFrame": 1193,
      "endFrame": 1207
    },
    {
      "id": "a23",
      "text": "苦笑い",
      "speaker": "narrator",
      "startFrame": 1208,
      "endFrame": 1222
    },
    {
      "id": "a24",
      "text": "呆れたような表情で",
      "speaker": "narrator",
      "startFrame": 1223,
      "endFrame": 1250
    },
    {
      "id": "a25",
      "text": "そして時は動き出す…",
      "speaker": "character1",
      "startFrame": 1251,
      "endFrame": 1275
    },
    {
      "id": "a26",
      "text": "って言ったら皆動き出した。",
      "speaker": "narrator",
      "startFrame": 1276,
      "endFrame": 1320
    },
    {
      "id": "a27",
      "text": "彼が一番面白かった。",
      "speaker": "narrator",
      "startFrame": 1321,
      "endFrame": 1370
    }
  ],
